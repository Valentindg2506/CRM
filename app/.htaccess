# Tinoprop - Configuracion Apache
# Compatible con Hostinger

# Proteger archivos sensibles
<FilesMatch "\.(php|ini|log|env)$">
    # Permitir acceso general a PHP
</FilesMatch>

# Bloquear acceso a archivos de configuracion
<FilesMatch "^(\.htaccess|\.env|composer\.(json|lock))$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Deshabilitar listado de directorios
Options -Indexes

# Charset por defecto
AddDefaultCharset UTF-8

# Seguridad headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings via .user.ini (Hostinger/LiteSpeed compatible)
# NOTA: Las directivas php_value NO funcionan en Hostinger (LiteSpeed).
# Usar .user.ini en la raiz del proyecto para configurar PHP.

# Comprimir respuestas
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache de archivos estaticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
